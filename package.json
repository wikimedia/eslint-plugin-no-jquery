{
	"name": "eslint-plugin-no-jquery",
	"version": "3.1.1",
	"description": "Disallow jQuery functions with native equivalents.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wikimedia/eslint-plugin-no-jquery.git"
	},
	"license": "MIT",
	"keywords": [
		"eslint",
		"eslintplugin",
		"eslint-plugin"
	],
	"main": "src/index.js",
	"scripts": {
		"pretest": "eslint --report-unused-disable-directives .",
		"test": "nyc mocha --reporter dot tests/** && git diff --exit-code docs/ src/ README.md",
		"onlytest": "mocha --reporter dot tests/**",
		"report": "nyc report --reporter=text-lcov > coverage.lcov",
		"reporthtml": "nyc report --reporter=html",
		"testpath": "mocha",
		"doc": "echo 'Documentation generation temporarily disabled pending eslint-docgen v9 update'",
		"build": "echo 'NOTE: Doc build temporarily disabled pending eslint-docgen v9 update; otherwise proceding'; node tools/build-all-methods.js"
	},
	"files": [
		"src"
	],
	"engine": {
		"node": ">=20"
	},
	"peerDependencies": {
		"eslint": ">=9.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.0.0",
		"@stylistic/eslint-plugin": "^3.0.0",
		"codecov": "^3.8.3",
		"eslint": "^9.0.0",
		"eslint-docgen": "^0.7.1",
		"eslint-plugin-eslint-plugin": "^6.5.0",
		"eslint-plugin-jsdoc": "^61.0.0",
		"eslint-plugin-mocha": "^10.0.0",
		"eslint-plugin-n": "^17.0.0",
		"eslint-plugin-security": "^3.0.0",
		"eslint-plugin-self": "^1.2.1",
		"eslint-plugin-unicorn": "^56.0.0",
		"jquery": "3.7.1",
		"jsdom": "^27.0.0",
		"mocha": "^11.7.4",
		"nyc": "^17.1.0"
	},
	"bugs": {
		"url": "https://github.com/wikimedia/eslint-plugin-no-jquery/issues"
	},
	"homepage": "https://github.com/wikimedia/eslint-plugin-no-jquery#readme",
	"directories": {
		"test": "tests"
	}
}
